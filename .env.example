# ─────────────────────────────────────────────────────────────────────────────
# ruudjuffermans-account — the platform's central auth + account dashboard.
# Client-only; the backend is ../ruudjuffermans-server (api.ruudjuffermans.nl).
#
# Local dev needs NO env: the Vite dev server (client/, port 3004) proxies
# /api/* to http://localhost:4000, so VITE_API_URL stays unset (base '').
# These keys only matter for the production docker compose build.
# ─────────────────────────────────────────────────────────────────────────────

# Platform API origin, inlined by Vite at build time (docker compose build arg).
VITE_API_URL=https://api.ruudjuffermans.nl
